# Repository allowlist. Runtime files are ignored by default.
/*

# Repo metadata
!/.editorconfig
!/.gitattributes
!/.gitignore
!/.prettierrc
!/.prettierignore
!/.github/
!/.github/**
!/.agents/
!/.agents/**
!/.husky/
!/.husky/**
!/.vscode/
/.vscode/*
!/.vscode/extensions.json

# Pack metadata and generated release-root files
!/package.json
!/package-lock.json
!/pack/
!/pack/**

# Docs and project assets
!/README.md
!/AGENTS.md
!/LICENSE
!/docs/
!/docs/**
!/modpack-analysis-report.md

# Launchers and local examples
!/devtool.bat

# Packwiz-managed downloads. Track descriptors, never downloaded jars/zips.
!/mods/
!/mods/*.pw.toml
!/resourcepacks/
!/resourcepacks/**
!/shaderpacks/
!/shaderpacks/**

# Maintained pack data
!/config/
!/defaultconfigs/
!/defaultconfigs/**
!/kubejs/
!/kubejs/**
!/ldlib/
!/ldlib/**
!/schematics/
!/schematics/**
!/tacz/
!/tacz/**
!/minemenu/
!/minemenu/**
!/scripts/
!/scripts/**
!/server/
!/server/**

# Explicit runtime exclusions inside allowed directories.
scripts/bin/*
!scripts/bin/packwiz.exe
!scripts/bin/packwiz.VERSION.txt
!scripts/bin/packwiz-installer-bootstrap.VERSION.txt
mods/*.jar
mods/*.jar.disabled
!scripts/bin/packwiz-installer-bootstrap.jar
logs/
crash-reports/
saves/
world/
world*/
libraries/
versions/
downloads/
node_modules/
server.properties
eula.txt
user_jvm_args.txt
run.bat
run.sh
neoforge.jar
minecraft_server*.jar
*.log
*.lock
*.tmp

.probe
kubejs/config/probe-settings.json
kubejs/config/web_server.json
