# Repository allowlist. Runtime files are ignored by default.
/*

# Repo metadata
!/.editorconfig
!/.gitattributes
!/.gitignore
!/.prettierrc
!/.prettierignore
!/.github/
!/.github/**
!/.agents/
!/.agents/**
!/.husky/
!/.husky/**
!/.vscode/
/.vscode/*
!/.vscode/extensions.json

# Pack metadata and generated release-root files
!/package.json
!/package-lock.json
!/.packwizignore
!/pack/
!/pack/**

# Docs and project assets
!/README.md
!/GettingStarted.md
!/AGENTS.md
!/LICENSE
!/docs/
!/docs/**
!/modpack-analysis-report.md
docs/generated/

# Launchers and local examples
!/devtool.bat
!/devtool.sh

# Packwiz-managed downloads. Track descriptors, never downloaded jars/zips.
!/mods/
!/mods/*.pw.toml
!/resourcepacks/
!/resourcepacks/**
!/shaderpacks/
!/shaderpacks/**

# Maintained pack data
!/config/
!/defaultconfigs/
!/defaultconfigs/**
!/kubejs/
!/kubejs/**
!/ldlib/
!/ldlib/**
!/hotai/
!/hotai/**
!/schematics/
!/schematics/**
!/tacz/
!/tacz/**
!/minemenu/
!/minemenu/**
!/roots/
!/roots/**
!/scripts/
!/scripts/**

# Explicit runtime exclusions inside allowed directories.
docs/generated/
scripts/bin/*
mods/*.jar
mods/*.jar.disabled
resourcepacks/*.zip
shaderpacks/*.zip
logs/
crash-reports/
saves/
/world/
/world*/
libraries/
versions/
downloads/
node_modules/
server.properties
eula.txt
user_jvm_args.txt
run.bat
run.sh
neoforge.jar
minecraft_server*.jar
*.log
*.lock
*.tmp

# Local dedicated test server runtime files.
test_server/
test_server/mods/*.jar
test_server/mods/*.jar.disabled
test_server/resourcepacks/*.zip
test_server/shaderpacks/*.zip
test_server/logs/
test_server/crash-reports/
test_server/world/
test_server/world*/
test_server/libraries/
test_server/versions/
test_server/downloads/
test_server/server.properties
test_server/eula.txt
test_server/user_jvm_args.txt
test_server/run.bat
test_server/run.sh
test_server/neoforge.jar
test_server/minecraft_server*.jar
test_server/*.log
test_server/*.lock
test_server/*.tmp

# Legacy local test server directory; keep ignored during migration.
server/
server/mods/*.jar
server/mods/*.jar.disabled
server/resourcepacks/*.zip
server/shaderpacks/*.zip
server/logs/
server/crash-reports/
server/world/
server/world*/
server/libraries/
server/versions/
server/downloads/
server/server.properties
server/eula.txt
server/user_jvm_args.txt
server/run.bat
server/run.sh
server/neoforge.jar
server/minecraft_server*.jar
server/*.log
server/*.lock
server/*.tmp

.probe
kubejs/config/probe-settings.json
kubejs/config/web_server.json
