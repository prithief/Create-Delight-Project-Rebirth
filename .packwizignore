# Pack distribution allowlist. Runtime files and repository-only files are
# ignored by default; use ! rules below for files that belong in the pack index.
/*

# Pack icon.
!/icon.png

# Packwiz-managed descriptors. Local downloaded jars/zips are ignored below.
!/mods/
!/mods/**
!/resourcepacks/
!/resourcepacks/**
!/shaderpacks/
!/shaderpacks/**

# Shared Minecraft configuration and authored pack data.
!/config/
!/config/**
/config/*
!/defaultconfigs/
!/defaultconfigs/**
/defaultconfigs/*
!/kubejs/
!/kubejs/**
!/ldlib/
!/ldlib/**
!/schematics/
!/schematics/**
!/tacz/
!/tacz/**
!/minemenu/
!/minemenu/**
!/PCL/
!/PCL/**

# Runtime/downloaded artifacts must not be distributed through packwiz index.
mods/*.jar
mods/*.jar.disabled
resourcepacks/*.zip
shaderpacks/*.zip
*.mrpack
*.zip
*.7z

# Repository/local state files inside otherwise allowed directories.
**/.gitignore
**/.DS_Store
Thumbs.db

# Local generated state.
logs/
crash-reports/
saves/
world/
world*/
libraries/
versions/
downloads/
server.properties
eula.txt
user_jvm_args.txt
run.bat
run.sh
neoforge.jar
minecraft_server*.jar
*.log
*.lock
*.tmp

# ProbeJS/local dev settings.
.probe
kubejs/config/probe-settings.json
kubejs/config/web_server.json
